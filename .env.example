# =============================================================================
# AI Interview Prep Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   Copy-Item .env.example .env
#
# NEVER commit .env to git. Only .env.example is tracked.
# =============================================================================

# --- LLM: Gemini (Primary) ---
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- LLM: Groq (Fallback) ---
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- LLM Behavior ---
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_WAIT=1.0
LLM_RETRY_MAX_WAIT=8.0
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=1024

# --- Supabase ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
